# ============================================================
# GML Backend — variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores.
# NUNCA versione o arquivo `.env` com chaves reais.
# ============================================================

# --- Servidor ---
PORT=3333
NODE_ENV=development

# Origens permitidas no CORS (separadas por vírgula). Use * para liberar todas.
CORS_ORIGIN=http://localhost:5173

# --- Integração com a LLM (Google Gemini) ---
# Obtenha sua chave em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# (Opcional) URL base da API generativa do Google.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Tempo limite (ms) para as chamadas à LLM.
GEMINI_TIMEOUT_MS=30000
# Tentativas extras em caso de erro transitório (5xx / timeout).
GEMINI_MAX_RETRIES=2

# --- Segurança (opcional) ---
# Se definida, protege as rotas de IA exigindo o header `x-api-key`.
# Deixe em branco para manter as rotas abertas (ambiente de demonstração).
API_KEY=

# --- Banco de dados (placeholder — ainda não utilizado) ---
DATABASE_URL=
